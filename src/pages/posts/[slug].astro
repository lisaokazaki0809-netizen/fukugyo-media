---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Sidebar from '../../components/Sidebar.astro';
import LeftSidebar from '../../components/LeftSidebar.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCategoryName, getCategoryColor, getCategoryBgColor, getCategoryImage } from '../../lib/categories';
import { SITE } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const catColor = getCategoryColor(post.data.category);
const catBgColor = getCategoryBgColor(post.data.category);
const catImage = getCategoryImage(post.data.category);

// 読了時間の計算（日本語は1分400文字で計算）
const body = post.body || '';
const charCount = body.length;
const readingTime = Math.max(1, Math.ceil(charCount / 400));

// シェアURL
const shareUrl = new URL(`/posts/${post.id}/`, SITE.url).toString();
const shareText = encodeURIComponent(post.data.title);

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((p) => p.data.category === post.data.category && p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: { '@type': 'Organization', name: SITE.author },
  publisher: { '@type': 'Organization', name: SITE.title },
  image: new URL(post.data.image, SITE.url).toString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(`/posts/${post.id}/`, SITE.url).toString() },
};
---

<Base
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  type="article"
  pubDate={post.data.pubDate}
  breadcrumbs={[
    { name: getCategoryName(post.data.category), href: `/category/${post.data.category}/` },
    { name: post.data.title, href: `/posts/${post.id}/` },
  ]}
>
  <div class="mx-auto max-w-7xl px-4 py-6 md:py-8">
    <div class="flex flex-col lg:flex-row gap-6">

      <!-- 左サイドバー -->
      <div class="hidden lg:block w-56 shrink-0">
        <LeftSidebar />
      </div>

      <!-- メインコンテンツ -->
      <article class="flex-1 min-w-0" data-pagefind-body>
        <!-- Hero image -->
        <div class="rounded-xl overflow-hidden aspect-[16/6] mb-6">
          <img src={catImage} alt="" class="w-full h-full object-cover" width="768" height="288" />
        </div>

        <!-- Meta -->
        <div class="flex items-center gap-2.5 mb-5">
          <a
            href={`/category/${post.data.category}/`}
            class="text-[11px] font-bold uppercase tracking-wide px-2 py-0.5 rounded transition-opacity hover:opacity-80"
            style={`color: ${catColor}; background-color: ${catBgColor}`}
          >
            {getCategoryName(post.data.category)}
          </a>
          <time datetime={post.data.pubDate.toISOString()} class="text-[13px] text-text-muted">
            {formattedDate}
          </time>
          <span class="text-[12px] text-text-muted flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {readingTime}分で読める
          </span>
        </div>

        <!-- Title -->
        <h1 class="text-2xl md:text-[1.75rem] font-bold text-text leading-tight mb-6">
          {post.data.title}
        </h1>

        <!-- SNSシェアボタン -->
        <div class="flex items-center gap-2 mb-6">
          <span class="text-[11px] text-text-muted mr-1">Share:</span>
          <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-bg-muted hover:bg-black hover:text-white flex items-center justify-center text-[12px] text-text-secondary transition-colors font-bold">X</a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-bg-muted hover:bg-blue-600 hover:text-white flex items-center justify-center text-[11px] text-text-secondary transition-colors font-bold">f</a>
          <a href={`https://b.hatena.ne.jp/entry/${shareUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-bg-muted hover:bg-sky-400 hover:text-white flex items-center justify-center text-[11px] text-text-secondary transition-colors font-bold">B!</a>
          <a href={`https://social-plugins.line.me/lineit/share?url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-bg-muted hover:bg-green-500 hover:text-white flex items-center justify-center text-[11px] text-text-secondary transition-colors font-bold">L</a>
        </div>

        <!-- Description card -->
        <div class="bg-bg-muted rounded-xl p-4 mb-6 text-[14px] text-text-secondary leading-relaxed">
          {post.data.description}
        </div>

        <!-- 目次 -->
        <TableOfContents />

        <!-- Body -->
        <div class="prose">
          <Content />
        </div>

        <!-- Tags -->
        {post.data.tags.length > 0 && (
          <div class="mt-10 pt-6 border-t border-border">
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <a
                  href={`/tag/${tag}/`}
                  class="text-[12px] bg-bg-muted text-text-secondary rounded-full px-3 py-1 hover:text-accent hover:bg-bg-muted transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- 記事末シェアボタン -->
        <div class="mt-10 pt-6 border-t border-border">
          <p class="text-[12px] text-text-muted mb-3">この記事が役に立ったらシェア</p>
          <div class="flex items-center gap-2">
            <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2.5 rounded-lg bg-black text-white text-[12px] font-bold hover:opacity-80 transition-opacity">X でポスト</a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2.5 rounded-lg bg-blue-600 text-white text-[12px] font-bold hover:opacity-80 transition-opacity">Facebook</a>
            <a href={`https://b.hatena.ne.jp/entry/${shareUrl}`} target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2.5 rounded-lg bg-sky-400 text-white text-[12px] font-bold hover:opacity-80 transition-opacity">はてブ</a>
            <a href={`https://social-plugins.line.me/lineit/share?url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2.5 rounded-lg bg-green-500 text-white text-[12px] font-bold hover:opacity-80 transition-opacity">LINE</a>
          </div>
        </div>

        <!-- Related posts -->
        {relatedPosts.length > 0 && (
          <section class="mt-12 pt-8 border-t border-border">
            <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-4">Related</h2>
            <div class="space-y-2">
              {relatedPosts.map((rp) => (
                <a
                  href={`/posts/${rp.id}/`}
                  class="flex items-start gap-3 p-3 rounded-lg hover:bg-bg-muted transition-colors"
                >
                  <span
                    class="text-[10px] font-bold uppercase tracking-wide px-1.5 py-0.5 rounded mt-0.5 shrink-0"
                    style={`color: ${getCategoryColor(rp.data.category)}; background-color: ${getCategoryBgColor(rp.data.category)}`}
                  >
                    {getCategoryName(rp.data.category)}
                  </span>
                  <span class="text-[14px] font-medium text-text leading-snug">{rp.data.title}</span>
                </a>
              ))}
            </div>
          </section>
        )}
      </article>

      <!-- サイドバー（PCのみ表示） -->
      <div class="hidden lg:block w-72 shrink-0">
        <Sidebar />
      </div>

    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</Base>
