---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPost = sortedPosts[0];
const restPosts = sortedPosts.slice(1);
---

<Base>
  <!-- Hero -->
  <section class="bg-primary text-white -mt-px">
    <div class="mx-auto max-w-6xl px-4 py-10 md:py-14">
      <p class="text-white/60 text-sm mb-2">副業と投資のリアルな調査記録</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-3">
        {SITE.title}
      </h1>
      <p class="text-white/70 text-sm md:text-base max-w-lg leading-relaxed">
        {SITE.description}
      </p>
    </div>
  </section>

  <!-- Category chips -->
  <section class="bg-bg-gray border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-4">
      <div class="flex flex-wrap gap-2">
        {Object.entries(categories).map(([slug, cat]) => (
          <a
            href={`/category/${slug}/`}
            class="text-xs font-semibold px-3 py-1.5 rounded-full transition-all hover:shadow-sm"
            style={`color: ${cat.color}; background-color: ${cat.bgColor}; border: 1px solid ${cat.color}20`}
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured post -->
  {latestPost && (
    <section class="mx-auto max-w-6xl px-4 pt-10">
      <div class="flex items-center gap-2 mb-4">
        <span class="bg-accent-light text-white text-xs font-bold px-2.5 py-1 rounded">NEW</span>
        <span class="text-sm font-semibold text-text">最新記事</span>
      </div>
      <a href={`/posts/${latestPost.id}/`} class="block group">
        <div class="bg-white border border-border rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
          <div class="h-2" style={`background-color: ${getCategoryColor(latestPost.data.category)}`}></div>
          <div class="p-6 md:p-8">
            <div class="flex items-center gap-3 mb-3">
              <span
                class="text-xs font-semibold px-2.5 py-1 rounded-md"
                style={`color: ${getCategoryColor(latestPost.data.category)}; background-color: ${getCategoryBgColor(latestPost.data.category)}`}
              >
                {categories[latestPost.data.category as keyof typeof categories]?.name}
              </span>
              <time class="text-xs text-text-muted">
                {latestPost.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
            <h2 class="text-xl md:text-2xl font-bold text-text group-hover:text-accent transition-colors mb-3">
              {latestPost.data.title}
            </h2>
            <p class="text-text-light text-sm md:text-base leading-relaxed max-w-2xl">
              {latestPost.data.description}
            </p>
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- All posts grid -->
  <section class="mx-auto max-w-6xl px-4 py-10">
    <h2 class="text-lg font-bold text-text mb-6 flex items-center gap-2">
      <span class="w-1 h-5 bg-accent rounded-full inline-block"></span>
      すべての記事
    </h2>
    {restPosts.length === 0 ? (
      <p class="text-text-light">まだ他の記事がありません。</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {restPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
          />
        ))}
      </div>
    )}
  </section>

  <!-- Category sections -->
  {Object.entries(categories).map(([slug, cat]) => {
    const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
    if (catPosts.length === 0) return null;
    return (
      <section class="mx-auto max-w-6xl px-4 pb-10">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-bold text-text flex items-center gap-2">
            <span class="w-1 h-5 rounded-full inline-block" style={`background-color: ${cat.color}`}></span>
            {cat.name}
          </h2>
          <a href={`/category/${slug}/`} class="text-sm text-text-light hover:text-accent transition-colors">
            もっと見る &rarr;
          </a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {catPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      </section>
    );
  })}
</Base>
