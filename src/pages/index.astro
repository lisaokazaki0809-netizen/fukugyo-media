---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.slice(0, 3);
const restPosts = sortedPosts.slice(3);
---

<Base hideHeader>
  <!-- Hero: 画像を丸ごと表示。クリック可能な領域を重ねる -->
  <section class="relative">
    <div class="mx-auto max-w-6xl">
      <!-- 画像MAP用にposition relativeのラッパーが必要 -->
      <div class="relative">
        <img
          src="/images/hero.jpg"
          alt="副業・投資・キャリアのリアルを記録するメディア わらじ二足"
          class="w-full h-auto block"
          width="1536"
          height="1024"
          fetchpriority="high"
          id="hero-img"
        />
        <!-- リンクはJSでピクセル単位で配置する -->
        <div id="hero-links"></div>
      </div>
    </div>
  </section>

  <!-- 記事一覧 -->
  <div id="articles" class="mx-auto max-w-6xl px-4 scroll-mt-4">
    {featuredPosts.length > 0 && (
      <section class="py-8">
        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">Pick Up</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {featuredPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              featured
            />
          ))}
        </div>
      </section>
    )}

    <hr class="border-border" />

    <section class="py-8">
      <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">All Articles</h2>
      {restPosts.length === 0 ? (
        <p class="text-text-secondary">まだ他の記事がありません。</p>
      ) : (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {restPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    {Object.entries(categories).map(([slug, cat]) => {
      const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
      if (catPosts.length === 0) return null;
      return (
        <>
          <hr class="border-border" />
          <section class="py-8">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-bold uppercase tracking-wider" style={`color: ${cat.color}`}>
                {cat.name}
              </h2>
              <a href={`/category/${slug}/`} class="text-[13px] text-text-muted hover:text-accent transition-colors">
                すべて見る &rarr;
              </a>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {catPosts.map((post) => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  slug={post.id}
                />
              ))}
            </div>
          </section>
        </>
      );
    })}
  </div>
</Base>

<script is:inline>
// 画像の元サイズに対するピクセル座標でリンクを定義
// 元画像: 1536 x 1024
var LINKS = [
  // ヘッダーナビ（左から順番に）
  { x: 15, y: 18, w: 180, h: 55, href: '/', label: 'トップ' },
  { x: 730, y: 18, w: 100, h: 55, href: '/category/investment/', label: '投資' },
  { x: 845, y: 18, w: 115, h: 55, href: '/category/ai/', label: 'AI副業' },
  { x: 975, y: 18, w: 85, h: 55, href: '/category/entrepreneur/', label: '起業' },
  { x: 1075, y: 18, w: 85, h: 55, href: '/category/jobchange/', label: '転職' },
  { x: 1170, y: 18, w: 165, h: 55, href: '/category/career/', label: 'キャリアアップ' },
  { x: 1350, y: 18, w: 110, h: 55, href: '/about/', label: 'About' },

  // CTAボタン
  { x: 50, y: 400, w: 440, h: 60, href: '#articles', label: '記事を見る' },

  // カテゴリカード5つ（左から順番に）
  { x: 30, y: 520, w: 275, h: 170, href: '/category/investment/', label: '投資' },
  { x: 318, y: 520, w: 275, h: 170, href: '/category/ai/', label: 'AI副業' },
  { x: 606, y: 520, w: 275, h: 170, href: '/category/entrepreneur/', label: '起業' },
  { x: 894, y: 520, w: 275, h: 170, href: '/category/jobchange/', label: '転職' },
  { x: 1182, y: 520, w: 275, h: 170, href: '/category/career/', label: 'キャリアアップ' },

  // このサイトについてエリア
  { x: 30, y: 720, w: 1476, h: 290, href: '/about/', label: 'このサイトについて' },
];

function placeLinks() {
  var img = document.getElementById('hero-img');
  var container = document.getElementById('hero-links');
  if (!img || !container) return;

  var displayW = img.clientWidth;
  var displayH = img.clientHeight;
  var origW = 1536;
  var origH = 1024;
  var scaleX = displayW / origW;
  var scaleY = displayH / origH;

  container.innerHTML = '';

  for (var i = 0; i < LINKS.length; i++) {
    var link = LINKS[i];
    var a = document.createElement('a');
    a.href = link.href;
    a.setAttribute('aria-label', link.label);
    a.style.position = 'absolute';
    a.style.left = (link.x * scaleX) + 'px';
    a.style.top = (link.y * scaleY) + 'px';
    a.style.width = (link.w * scaleX) + 'px';
    a.style.height = (link.h * scaleY) + 'px';
    a.style.cursor = 'pointer';
    a.style.background = 'rgba(255,0,0,0.15)'; // デバッグ用
    container.appendChild(a);
  }
}

// 画像読み込み後とリサイズ時に再配置
window.addEventListener('load', placeLinks);
window.addEventListener('resize', placeLinks);
</script>
