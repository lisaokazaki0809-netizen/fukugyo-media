---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.slice(0, 3);
const restPosts = sortedPosts.slice(3);
---

<Base hideHeader>
  <!-- Hero: 画像を丸ごと表示。クリック可能な領域を重ねる -->
  <section class="relative">
    <div class="mx-auto max-w-6xl">
      <!-- 画像MAP用にposition relativeのラッパーが必要 -->
      <div class="relative">
        <img
          src="/images/hero.jpg"
          alt="副業・投資・キャリアのリアルを記録するメディア わらじ二足"
          class="w-full h-auto block"
          width="1536"
          height="1024"
          fetchpriority="high"
          id="hero-img"
        />
        <!-- ロゴ上書き: 画像内の「わらじ二足」を「副業media」に差し替え -->
        <div id="hero-logo" class="absolute flex items-center" style="background:#f8fafc;">
          <span style="font-size:inherit; font-weight:800; color:#1a1a2e; letter-spacing:-0.02em; white-space:nowrap;">副業media</span>
        </div>
        <!-- リンクはJSでピクセル単位で配置する -->
        <div id="hero-links"></div>
      </div>
    </div>
  </section>

  <!-- 記事一覧 -->
  <div id="articles" class="mx-auto max-w-6xl px-4 scroll-mt-4">
    {featuredPosts.length > 0 && (
      <section class="py-8">
        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">Pick Up</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {featuredPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              featured
            />
          ))}
        </div>
      </section>
    )}

    <hr class="border-border" />

    <section class="py-8">
      <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">All Articles</h2>
      {restPosts.length === 0 ? (
        <p class="text-text-secondary">まだ他の記事がありません。</p>
      ) : (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {restPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    {Object.entries(categories).map(([slug, cat]) => {
      const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
      if (catPosts.length === 0) return null;
      return (
        <>
          <hr class="border-border" />
          <section class="py-8">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-bold uppercase tracking-wider" style={`color: ${cat.color}`}>
                {cat.name}
              </h2>
              <a href={`/category/${slug}/`} class="text-[13px] text-text-muted hover:text-accent transition-colors">
                すべて見る &rarr;
              </a>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {catPosts.map((post) => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  slug={post.id}
                />
              ))}
            </div>
          </section>
        </>
      );
    })}
  </div>
</Base>

<script is:inline>
// 画像の元サイズに対するピクセル座標でリンクを定義
// 元画像: 1536 x 1024
var LINKS = [
  // ヘッダーナビ
  { x: 32, y: 18, w: 180, h: 55, href: '/', label: 'トップ' },
  { x: 710, y: 17, w: 100, h: 55, href: '/category/investment/', label: '投資' },
  { x: 834, y: 18, w: 115, h: 55, href: '/category/ai/', label: 'AI副業' },
  { x: 983, y: 18, w: 85, h: 55, href: '/category/entrepreneur/', label: '起業' },
  { x: 1112, y: 19, w: 85, h: 55, href: '/category/jobchange/', label: '転職' },
  { x: 1234, y: 18, w: 165, h: 55, href: '/category/career/', label: 'キャリアアップ' },
  { x: 1411, y: 18, w: 110, h: 55, href: '/about/', label: 'About' },

  // CTAボタン
  { x: 74, y: 461, w: 440, h: 60, href: '#articles', label: '記事を見る' },

  // カテゴリカード5つ
  { x: 74, y: 568, w: 275, h: 170, href: '/category/investment/', label: '投資' },
  { x: 355, y: 565, w: 275, h: 170, href: '/category/ai/', label: 'AI副業' },
  { x: 637, y: 568, w: 275, h: 170, href: '/category/entrepreneur/', label: '起業' },
  { x: 915, y: 569, w: 275, h: 170, href: '/category/jobchange/', label: '転職' },
  { x: 1197, y: 568, w: 275, h: 170, href: '/category/career/', label: 'キャリアアップ' },

  // このサイトについて
  { x: 43, y: 747, w: 1476, h: 290, href: '/about/', label: 'このサイトについて' },
];

function placeLinks() {
  var img = document.getElementById('hero-img');
  var container = document.getElementById('hero-links');
  if (!img || !container) return;

  var displayW = img.clientWidth;
  var displayH = img.clientHeight;
  var origW = 1536;
  var origH = 1024;
  var scaleX = displayW / origW;
  var scaleY = displayH / origH;

  // ロゴ上書きの位置とサイズを合わせる
  var logo = document.getElementById('hero-logo');
  if (logo) {
    logo.style.left = (32 * scaleX) + 'px';
    logo.style.top = (18 * scaleY) + 'px';
    logo.style.width = (180 * scaleX) + 'px';
    logo.style.height = (55 * scaleY) + 'px';
    logo.style.fontSize = (28 * scaleX) + 'px';
    logo.style.paddingLeft = (6 * scaleX) + 'px';
  }

  container.innerHTML = '';

  for (var i = 0; i < LINKS.length; i++) {
    var link = LINKS[i];
    var a = document.createElement('a');
    a.href = link.href;
    a.setAttribute('aria-label', link.label);
    a.style.position = 'absolute';
    a.style.left = (link.x * scaleX) + 'px';
    a.style.top = (link.y * scaleY) + 'px';
    a.style.width = (link.w * scaleX) + 'px';
    a.style.height = (link.h * scaleY) + 'px';
    a.style.cursor = 'pointer';
    // 本番: 透明リンク
    container.appendChild(a);
  }
}

window.addEventListener('load', placeLinks);
window.addEventListener('resize', placeLinks);
</script>
