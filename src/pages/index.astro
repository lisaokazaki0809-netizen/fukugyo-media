---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import LeftSidebar from '../components/LeftSidebar.astro';
import { categories, getCategoryColor, getCategoryBgColor, getCategoryName, getCategoryImage, getFeaturedHeroImage } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPost = sortedPosts[0];
const sideFeaturePosts = sortedPosts.slice(1, 3);
const recommendedPosts = sortedPosts.slice(0, 3);
const latestPosts = sortedPosts.slice(3);
---

<Base>
  <div class="mx-auto max-w-7xl px-4 py-6">
    <div class="flex flex-col lg:flex-row gap-6">

      <!-- 左サイドバー -->
      <div class="hidden lg:block w-56 shrink-0">
        <LeftSidebar />
      </div>

      <!-- メインコンテンツ -->
      <div class="flex-1 min-w-0">

        <!-- FV: 人ベース。写真+感情コピー -->
        <section class="mb-6 relative rounded-2xl overflow-hidden">
          <img
            src={getFeaturedHeroImage()}
            alt=""
            class="w-full h-auto min-h-[280px] object-cover"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/60 to-transparent"></div>
          <div class="absolute inset-0 flex items-center">
            <div class="p-6 md:p-8 max-w-md">
              <h1 class="text-xl md:text-[1.65rem] font-bold text-white leading-tight mb-3">
                このままでいいのかな、<br/>って思うことがある。
              </h1>
              <p class="text-white/60 text-[13px] leading-relaxed mb-5">
                副業、投資、転職。気になってるけど動けていない。そんな30代のための、リアルな情報メディア。
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                <a href="/category/investment/" class="bg-white/15 hover:bg-white/30 text-white text-[12px] font-medium px-4 py-2 rounded-full transition-colors border border-white/20 backdrop-blur-sm">
                  副業・投資を始めたい
                </a>
                <a href="/category/jobchange/" class="bg-white/15 hover:bg-white/30 text-white text-[12px] font-medium px-4 py-2 rounded-full transition-colors border border-white/20 backdrop-blur-sm">
                  転職を考えている
                </a>
                <a href="/category/career/" class="bg-white/15 hover:bg-white/30 text-white text-[12px] font-medium px-4 py-2 rounded-full transition-colors border border-white/20 backdrop-blur-sm">
                  年収を上げたい
                </a>
              </div>
              <a href="/posts/side-job-beginners-guide/" class="inline-flex items-center gap-2 bg-white text-primary text-[13px] font-bold px-5 py-2.5 rounded-lg hover:shadow-lg transition-all hover:translate-x-0.5">
                はじめての方はこちら &rsaquo;
              </a>
            </div>
          </div>
        </section>

        <!-- ▼ 特集：主役記事（圧倒的に目立つ） -->
        <section class="mb-6">
          <a href={`/posts/${featuredPost.id}/`} class="block group relative rounded-2xl overflow-hidden shadow-2xl ring-1 ring-black/10">
            <div class="aspect-[16/7]">
              <img
                src={getCategoryImage(featuredPost.data.category)}
                alt=""
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
              />
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/5"></div>
            <div class="absolute top-4 left-5 flex items-center gap-2">
              <span class="bg-red-500 text-white text-[12px] font-bold px-3 py-1.5 rounded-lg shadow-lg">🔥 今週の特集</span>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
              <span
                class="text-[11px] font-bold px-3 py-1 rounded-lg mb-3 inline-block"
                style={`color: white; background-color: ${getCategoryColor(featuredPost.data.category)}`}
              >
                {getCategoryName(featuredPost.data.category)}
              </span>
              <h2 class="text-white text-xl md:text-[1.75rem] font-bold leading-tight mb-3 max-w-xl drop-shadow-lg">
                {featuredPost.data.title}
              </h2>
              <p class="text-white/70 text-[14px] line-clamp-2 mb-4 max-w-lg">
                {featuredPost.data.description}
              </p>
              <span class="inline-flex items-center gap-2 bg-white text-primary text-[13px] font-bold px-5 py-2.5 rounded-lg shadow-md group-hover:shadow-lg transition-shadow">
                この記事を読む &rsaquo;
              </span>
            </div>
          </a>
        </section>

        <!-- ▼ 編集部のおすすめ（2枚。サブ） -->
        <section class="mb-8">
          <p class="text-[11px] font-bold text-text-muted uppercase tracking-wider mb-3">EDITOR'S PICK</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {sideFeaturePosts.map((post) => (
              <a href={`/posts/${post.id}/`} class="group relative rounded-xl overflow-hidden aspect-[16/9] shadow-md ring-1 ring-black/5">
                <img
                  src={getCategoryImage(post.data.category, 1)}
                  alt=""
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"></div>
                <div class="absolute top-2.5 left-3">
                  <span class="text-[10px] font-bold px-2 py-0.5 rounded" style={`color: white; background-color: ${getCategoryColor(post.data.category)}cc`}>
                    {getCategoryName(post.data.category)}
                  </span>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-4">
                  <h3 class="text-white text-[14px] font-bold leading-snug line-clamp-2">{post.data.title}</h3>
                  <p class="text-white/40 text-[11px] mt-1.5">{post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

        <!-- ▼ 失敗談ゾーン（信頼+差別化） -->
        <section class="mb-8 bg-amber-50 border border-amber-200 rounded-2xl p-5">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">⚠️</span>
            <h2 class="text-[15px] font-bold text-text">正直に書いた「やめておけ」の話</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <a href="/posts/fx-kawase-kiken/" class="flex items-start gap-3 bg-white rounded-xl p-4 hover:shadow-sm transition-shadow group">
              <span class="text-xl shrink-0">😰</span>
              <div>
                <p class="text-[13px] font-bold text-text group-hover:text-accent transition-colors leading-snug">FXは正直キツかった。リスクを計算して分かったこと</p>
                <p class="text-[11px] text-text-muted mt-1">7割が負けている現実</p>
              </div>
            </a>
            <a href="/posts/crypto-hajimete-risuku/" class="flex items-start gap-3 bg-white rounded-xl p-4 hover:shadow-sm transition-shadow group">
              <span class="text-xl shrink-0">💸</span>
              <div>
                <p class="text-[13px] font-bold text-text group-hover:text-accent transition-colors leading-snug">仮想通貨で副業は危険？税金55%の現実</p>
                <p class="text-[11px] text-text-muted mt-1">株より明らかに不利だった</p>
              </div>
            </a>
          </div>
        </section>

        <!-- ▼ ショートカットナビ -->
        <section class="mb-8">
          <div class="grid grid-cols-4 gap-3">
            <a href="/posts/side-job-beginners-guide/" class="bg-white border border-border rounded-xl p-3 text-center hover:border-accent hover:shadow-sm transition-all group">
              <span class="text-lg block">📝</span>
              <p class="text-[11px] font-bold text-text mt-1 group-hover:text-accent transition-colors">初心者向け記事</p>
            </a>
            <a href="#popular" class="bg-white border border-border rounded-xl p-3 text-center hover:border-accent hover:shadow-sm transition-all group">
              <span class="text-lg block">🔥</span>
              <p class="text-[11px] font-bold text-text mt-1 group-hover:text-accent transition-colors">人気記事</p>
            </a>
            <a href="#latest" class="bg-white border border-border rounded-xl p-3 text-center hover:border-accent hover:shadow-sm transition-all group">
              <span class="text-lg block">🆕</span>
              <p class="text-[11px] font-bold text-text mt-1 group-hover:text-accent transition-colors">新着記事</p>
            </a>
            <a href="/search/" class="bg-white border border-border rounded-xl p-3 text-center hover:border-accent hover:shadow-sm transition-all group">
              <span class="text-lg block">📂</span>
              <p class="text-[11px] font-bold text-text mt-1 group-hover:text-accent transition-colors">カテゴリ一覧</p>
            </a>
          </div>
        </section>

        <!-- ▼ まず読むべき3記事（編集感。番号付き） -->
        <section id="popular" class="mb-8">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-[16px] font-bold text-text flex items-center gap-2">
              <span class="bg-accent text-white text-[10px] font-bold px-2 py-0.5 rounded">STEP</span>
              まず読むべきおすすめ記事
            </h2>
            <a href="/search/" class="text-[12px] text-text-muted hover:text-accent transition-colors">もっと見る</a>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
            {recommendedPosts.map((post, i) => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                category={post.data.category}
                slug={post.id}
                index={i}
              />
            ))}
          </div>
        </section>

        <!-- 新着記事 -->
        <section id="latest" class="mb-8">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-[16px] font-bold text-text">新着記事</h2>
            <a href="/search/" class="text-[12px] text-text-muted hover:text-accent transition-colors">もっと見る</a>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
            {latestPosts.slice(0, 9).map((post, i) => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                category={post.data.category}
                slug={post.id}
                index={i + 1}
              />
            ))}
          </div>
        </section>

        <!-- カテゴリ別セクション -->
        {Object.entries(categories).map(([slug, cat]) => {
          const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
          if (catPosts.length === 0) return null;
          return (
            <section class="mb-8">
              <div class="flex items-center justify-between mb-5">
                <h2 class="text-[16px] font-bold flex items-center gap-2" style={`color: ${cat.color}`}>
                  <span class="w-1.5 h-5 rounded-full" style={`background-color: ${cat.color}`}></span>
                  {cat.name}
                </h2>
                <a href={`/category/${slug}/`} class="text-[12px] text-text-muted hover:text-accent transition-colors">
                  もっと見る
                </a>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
                {catPosts.map((post, i) => (
                  <ArticleCard
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    category={post.data.category}
                    slug={post.id}
                    index={i}
                  />
                ))}
              </div>
            </section>
          );
        })}

        <!-- 下部PR -->
        <section class="mb-8">
          <div class="bg-gradient-to-r from-blue-50 to-green-50 border border-border rounded-xl p-6 flex flex-col md:flex-row items-center gap-6">
            <div class="flex-1">
              <span class="text-[10px] font-bold text-accent bg-accent/10 px-2 py-0.5 rounded mb-2 inline-block">PR</span>
              <h3 class="text-[17px] font-bold text-text mb-2">未経験からでも始められる<br/>おすすめ副業を厳選！</h3>
              <p class="text-[12px] text-text-secondary mb-4">実際に月3万円以上稼げた方法だけをまとめました。あなたに合った副業がきっと見つかります。</p>
              <span class="inline-block bg-accent text-white text-[13px] font-bold px-5 py-2.5 rounded-lg">
                無料で詳細をチェック &rsaquo;
              </span>
            </div>
            <div class="w-48 h-32 bg-white/50 rounded-xl flex items-center justify-center text-text-muted text-[12px]">
              広告画像エリア
            </div>
          </div>
        </section>

      </div><!-- /メインコンテンツ -->

    </div>
  </div>
</Base>

<script is:inline>
// ヒーロー画像のリンクは不要（トップページのFVは新デザイン）
</script>
