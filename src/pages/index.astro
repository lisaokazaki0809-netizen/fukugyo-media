---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import LeftSidebar from '../components/LeftSidebar.astro';
import { categories, getCategoryColor, getCategoryBgColor, getCategoryName, getCategoryImage, getFeaturedHeroImage } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPost = sortedPosts[0];
const sideFeaturePosts = sortedPosts.slice(1, 3);
const recommendedPosts = sortedPosts.slice(0, 3);
const latestPosts = sortedPosts.slice(3);
---

<Base>
  <div class="mx-auto max-w-7xl px-4 py-6">
    <div class="flex flex-col lg:flex-row gap-6">

      <!-- 左サイドバー -->
      <div class="hidden lg:block w-56 shrink-0">
        <LeftSidebar />
      </div>

      <!-- メインコンテンツ -->
      <div class="flex-1 min-w-0">

        <!-- FV: 刺さるコピー + 選択肢 -->
        <section class="mb-6 bg-gradient-to-br from-primary to-primary-light rounded-2xl p-6 md:p-8 text-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-accent/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
          <div class="relative">
            <p class="text-white/60 text-[12px] font-medium mb-2">副業・投資・キャリアのリアルな情報メディア</p>
            <h1 class="text-xl md:text-2xl font-bold leading-tight mb-3">
              何から始めればいいか<br/>分からない人へ。
            </h1>
            <p class="text-white/70 text-[13px] leading-relaxed mb-5 max-w-md">
              煽らない。盛らない。30代会社員が実際に調べて、比較して、考えた記録だけを正直に発信しています。
            </p>
            <p class="text-white/50 text-[11px] font-bold uppercase tracking-wider mb-3">あなたが今、気になっているのは？</p>
            <div class="flex flex-wrap gap-2 mb-4">
              <a href="/category/investment/" class="bg-white/15 hover:bg-white/25 text-white text-[12px] font-medium px-4 py-2 rounded-full transition-colors border border-white/20">
                💰 副業・投資を始めたい
              </a>
              <a href="/category/jobchange/" class="bg-white/15 hover:bg-white/25 text-white text-[12px] font-medium px-4 py-2 rounded-full transition-colors border border-white/20">
                🔄 転職を考えている
              </a>
              <a href="/category/career/" class="bg-white/15 hover:bg-white/25 text-white text-[12px] font-medium px-4 py-2 rounded-full transition-colors border border-white/20">
                📈 年収を上げたい
              </a>
            </div>
            <a href="/posts/side-job-beginners-guide/" class="inline-flex items-center gap-2 bg-white text-primary text-[13px] font-bold px-5 py-2.5 rounded-lg hover:shadow-lg transition-shadow">
              初心者ガイドを読む &rsaquo;
            </a>
          </div>
        </section>

        <!-- 注目記事（主役。大きく・濃く・影つき） -->
        <section class="mb-8">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="md:col-span-2">
              <a href={`/posts/${featuredPost.id}/`} class="block group relative rounded-2xl overflow-hidden aspect-[16/10] shadow-xl ring-1 ring-black/5">
                <img
                  src={getFeaturedHeroImage()}
                  alt=""
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-black/10"></div>
                <div class="absolute top-4 left-4">
                  <span class="bg-red-500 text-white text-[11px] font-bold px-3 py-1 rounded-full animate-pulse">🔥 注目</span>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
                  <span
                    class="text-[10px] font-bold px-2 py-0.5 rounded mb-2 inline-block"
                    style={`color: white; background-color: ${getCategoryColor(featuredPost.data.category)}`}
                  >
                    {getCategoryName(featuredPost.data.category)}
                  </span>
                  <h2 class="text-white text-lg md:text-xl font-bold leading-snug mb-2">
                    {featuredPost.data.title}
                  </h2>
                  <p class="text-white/75 text-[13px] line-clamp-2 mb-3">
                    {featuredPost.data.description}
                  </p>
                  <span class="text-white/50 text-[12px]">
                    {featuredPost.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}
                  </span>
                </div>
              </a>
            </div>

            <div class="flex flex-col gap-4">
              {sideFeaturePosts.map((post) => (
                <a href={`/posts/${post.id}/`} class="group relative rounded-xl overflow-hidden aspect-[16/9] flex-1 shadow-md ring-1 ring-black/5">
                  <img
                    src={getCategoryImage(post.data.category, 1)}
                    alt=""
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/75 to-transparent"></div>
                  <div class="absolute top-2 left-2">
                    <span
                      class="text-[10px] font-bold px-2 py-0.5 rounded"
                      style={`color: white; background-color: ${getCategoryColor(post.data.category)}`}
                    >
                      {getCategoryName(post.data.category)}
                    </span>
                  </div>
                  <div class="absolute bottom-0 left-0 right-0 p-3">
                    <h3 class="text-white text-[13px] font-bold leading-snug line-clamp-2">
                      {post.data.title}
                    </h3>
                    <p class="text-white/50 text-[11px] mt-1">
                      {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>

        <!-- バリュープロポジション -->
        <section class="mb-8">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="bg-white border border-border rounded-xl p-4 text-center">
              <span class="text-2xl block mb-2">📝</span>
              <p class="text-[13px] font-bold text-text mb-1">リアルな体験記録</p>
              <p class="text-[11px] text-text-muted leading-snug">実際にやってみたことだけを正直に発信します</p>
            </div>
            <div class="bg-white border border-border rounded-xl p-4 text-center">
              <span class="text-2xl block mb-2">🔰</span>
              <p class="text-[13px] font-bold text-text mb-1">初心者目線</p>
              <p class="text-[11px] text-text-muted leading-snug">難しいことをわかりやすく、つまずきやすい部分も解説</p>
            </div>
            <div class="bg-white border border-border rounded-xl p-4 text-center">
              <span class="text-2xl block mb-2">🚀</span>
              <p class="text-[13px] font-bold text-text mb-1">行動につながる</p>
              <p class="text-[11px] text-text-muted leading-snug">読むだけで終わらず、次の一歩を踏み出せる内容を</p>
            </div>
            <div class="bg-white border border-border rounded-xl p-4 text-center">
              <span class="text-2xl block mb-2">⚖️</span>
              <p class="text-[13px] font-bold text-text mb-1">中立・客観的</p>
              <p class="text-[11px] text-text-muted leading-snug">特定のサービスに偏らず、本当に良いものを紹介</p>
            </div>
          </div>
        </section>

        <!-- まず読むべきおすすめ記事 -->
        <section id="popular" class="mb-8">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-[16px] font-bold text-text">まず読むべきおすすめ記事</h2>
            <a href="/search/" class="text-[12px] text-text-muted hover:text-accent transition-colors">もっと見る</a>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
            {recommendedPosts.map((post, i) => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                category={post.data.category}
                slug={post.id}
                index={i}
              />
            ))}
          </div>
        </section>

        <!-- 新着記事 -->
        <section id="latest" class="mb-8">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-[16px] font-bold text-text">新着記事</h2>
            <a href="/search/" class="text-[12px] text-text-muted hover:text-accent transition-colors">もっと見る</a>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
            {latestPosts.slice(0, 9).map((post, i) => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                category={post.data.category}
                slug={post.id}
                index={i + 1}
              />
            ))}
          </div>
        </section>

        <!-- カテゴリ別セクション -->
        {Object.entries(categories).map(([slug, cat]) => {
          const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
          if (catPosts.length === 0) return null;
          return (
            <section class="mb-8">
              <div class="flex items-center justify-between mb-5">
                <h2 class="text-[16px] font-bold flex items-center gap-2" style={`color: ${cat.color}`}>
                  <span class="w-1.5 h-5 rounded-full" style={`background-color: ${cat.color}`}></span>
                  {cat.name}
                </h2>
                <a href={`/category/${slug}/`} class="text-[12px] text-text-muted hover:text-accent transition-colors">
                  もっと見る
                </a>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
                {catPosts.map((post, i) => (
                  <ArticleCard
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    category={post.data.category}
                    slug={post.id}
                    index={i}
                  />
                ))}
              </div>
            </section>
          );
        })}

        <!-- 下部PR -->
        <section class="mb-8">
          <div class="bg-gradient-to-r from-blue-50 to-green-50 border border-border rounded-xl p-6 flex flex-col md:flex-row items-center gap-6">
            <div class="flex-1">
              <span class="text-[10px] font-bold text-accent bg-accent/10 px-2 py-0.5 rounded mb-2 inline-block">PR</span>
              <h3 class="text-[17px] font-bold text-text mb-2">未経験からでも始められる<br/>おすすめ副業を厳選！</h3>
              <p class="text-[12px] text-text-secondary mb-4">実際に月3万円以上稼げた方法だけをまとめました。あなたに合った副業がきっと見つかります。</p>
              <span class="inline-block bg-accent text-white text-[13px] font-bold px-5 py-2.5 rounded-lg">
                無料で詳細をチェック &rsaquo;
              </span>
            </div>
            <div class="w-48 h-32 bg-white/50 rounded-xl flex items-center justify-center text-text-muted text-[12px]">
              広告画像エリア
            </div>
          </div>
        </section>

      </div><!-- /メインコンテンツ -->

    </div>
  </div>
</Base>

<script is:inline>
// ヒーロー画像のリンクは不要（トップページのFVは新デザイン）
</script>
