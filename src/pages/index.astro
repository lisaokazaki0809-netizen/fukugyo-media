---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.slice(0, 3);
const restPosts = sortedPosts.slice(3);

const categoryIcons: Record<string, string> = {
  investment: '&#128200;',
  ai: '&#129302;',
  entrepreneur: '&#128161;',
  jobchange: '&#128231;',
  career: '&#128202;',
};
---

<Base hideHeader>
  <!-- Hero image (上部60%だけ表示、カテゴリカード以下はHTMLで再現) -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl">
      <div class="relative overflow-hidden" style="max-height: 480px;">
        <img
          src="/images/hero.jpg"
          alt="副業・投資・キャリアのリアルを記録するメディア わらじ二足"
          class="w-full h-auto"
          width="1536"
          height="1024"
          fetchpriority="high"
          style="margin-top: -2%; margin-bottom: -42%;"
        />
      </div>
      <!-- CTAボタンの透明リンク -->
      <a
        href="#articles"
        class="absolute bottom-[18%] left-[3%] md:left-[3%] w-[32%] md:w-[26%] h-[10%] md:h-[12%] rounded-full"
        aria-label="情報を比較して、自分らしい選択を見つけよう"
      ></a>
    </div>
  </section>

  <!-- カテゴリナビ（HTML版。画像内のカテゴリカードを再現） -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-6">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {Object.entries(categories).map(([slug, cat]) => (
          <a
            href={`/category/${slug}/`}
            class="group flex items-start gap-3 p-4 rounded-xl border border-border hover:border-accent/30 hover:shadow-sm transition-all bg-white"
          >
            <div class="text-2xl shrink-0 mt-0.5" set:html={categoryIcons[slug]} />
            <div class="min-w-0">
              <p class="font-bold text-[15px] group-hover:text-accent transition-colors" style={`color: ${cat.color}`}>
                {cat.name}
              </p>
              <p class="text-[12px] text-text-muted leading-snug mt-0.5 line-clamp-2">
                {cat.description.replace(/など|の選び方|の始め方と稼ぎ方|の立ち上げガイド/g, '')}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- このサイトについて -->
  <section class="bg-bg-soft border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-10">
      <h2 class="text-xl font-bold text-text mb-6">このサイトについて</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 border border-border">
          <p class="font-bold text-[15px] text-text mb-2">書いている人</p>
          <p class="text-[14px] text-text-secondary leading-relaxed">
            30代の会社員です。本業を続けながら、副業や投資、転職やキャリアアップについて調べたり比較したりしています。
            調べた内容や考えたことを、盛らずに記録しています。
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-border">
          <p class="font-bold text-[15px] text-text mb-2">なぜ書くのか</p>
          <p class="text-[14px] text-text-secondary leading-relaxed">
            ネット上の副業情報は煽り記事が多くて、冷静に比較検討できる情報が少ないと感じていました。
            自分が調べたことをそのまま書くことで、同じように検討している方の参考になればと思っています。
          </p>
        </div>
      </div>
      <div class="mt-4 text-right">
        <a href="/about/" class="text-[13px] text-accent hover:underline">
          もっと詳しく &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- 記事一覧 -->
  <div id="articles" class="mx-auto max-w-6xl px-4 scroll-mt-4">
    <!-- Featured posts -->
    {featuredPosts.length > 0 && (
      <section class="py-8">
        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">Pick Up</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {featuredPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              featured
            />
          ))}
        </div>
      </section>
    )}

    <hr class="border-border" />

    <!-- All posts -->
    <section class="py-8">
      <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">All Articles</h2>
      {restPosts.length === 0 ? (
        <p class="text-text-secondary">まだ他の記事がありません。</p>
      ) : (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {restPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    <!-- Category sections -->
    {Object.entries(categories).map(([slug, cat]) => {
      const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
      if (catPosts.length === 0) return null;
      return (
        <>
          <hr class="border-border" />
          <section class="py-8">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-bold uppercase tracking-wider" style={`color: ${cat.color}`}>
                {cat.name}
              </h2>
              <a href={`/category/${slug}/`} class="text-[13px] text-text-muted hover:text-accent transition-colors">
                すべて見る &rarr;
              </a>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {catPosts.map((post) => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  slug={post.id}
                />
              ))}
            </div>
          </section>
        </>
      );
    })}
  </div>
</Base>
