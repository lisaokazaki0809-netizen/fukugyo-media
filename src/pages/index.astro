---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.slice(0, 3);
const restPosts = sortedPosts.slice(3);
---

<Base>
  <!-- Hero ビジュアル -->
  <section class="bg-gradient-to-br from-slate-50 to-blue-50">
    <div class="mx-auto max-w-6xl px-4 py-10 md:py-16">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <p class="text-text-muted text-sm mb-3">本業を続けながら、未来の選択肢を広げる</p>
          <h1 class="text-3xl md:text-4xl font-bold text-text leading-tight mb-4">
            副業・投資・キャリアの<br />
            <span class="text-accent">リアル</span>を記録するメディア
          </h1>
          <p class="text-text-secondary text-[15px] leading-relaxed mb-6">
            30代会社員が実際に調べて、比較して、考えたことを<br class="hidden md:inline" />
            正直にまとめています。
          </p>
          <a
            href="#articles"
            class="inline-flex items-center gap-2 border-2 border-text text-text px-6 py-3 rounded-full text-[14px] font-medium hover:bg-text hover:text-white transition-colors"
          >
            情報を比較して、自分らしい選択を見つけよう
            <span>&rsaquo;</span>
          </a>
        </div>
        <div class="hidden md:block">
          <img
            src="/images/hero-visual.jpg"
            alt="副業・投資の調査イメージ"
            class="w-full h-auto rounded-2xl shadow-lg"
            width="800"
            height="480"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- カテゴリナビ -->
  <section class="bg-white border-y border-border">
    <div class="mx-auto max-w-6xl px-4 py-6">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {Object.entries(categories).map(([slug, cat]) => (
          <a
            href={`/category/${slug}/`}
            class="group flex flex-col gap-1.5 p-4 rounded-xl border border-border hover:shadow-md transition-all"
          >
            <p class="text-[16px] font-bold group-hover:opacity-80 transition-opacity" style={`color: ${cat.color}`}>
              {cat.name}
            </p>
            <p class="text-[12px] text-text-muted leading-snug">
              {cat.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- このサイトについて -->
  <section class="bg-bg-soft border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-8">
      <h2 class="text-lg font-bold text-text mb-5">このサイトについて</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl p-5 border border-border">
          <p class="font-bold text-[14px] text-text mb-2">書いている人</p>
          <p class="text-[13px] text-text-secondary leading-relaxed">
            30代の会社員です。本業を続けながら、副業や投資、転職やキャリアアップについて調べたり比較したりしています。
          </p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-border">
          <p class="font-bold text-[14px] text-text mb-2">なぜ書くのか</p>
          <p class="text-[13px] text-text-secondary leading-relaxed">
            ネット上の副業情報は煽り記事が多くて、冷静に比較検討できる情報が少ないと感じていました。盛らずにそのまま書いています。
          </p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-border">
          <p class="font-bold text-[14px] text-text mb-2">扱うジャンル</p>
          <ul class="text-[13px] text-text-secondary leading-relaxed space-y-1">
            {Object.entries(categories).map(([_, cat]) => (
              <li><span class="font-medium text-text">{cat.name}</span></li>
            ))}
          </ul>
        </div>
        <div class="bg-white rounded-xl p-5 border border-border">
          <p class="font-bold text-[14px] text-text mb-2">注意事項</p>
          <p class="text-[13px] text-text-secondary leading-relaxed">
            あくまで個人が調べた内容の記録です。特定の副業や投資を推奨するものではありません。判断はご自身の責任でお願いします。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 記事一覧 -->
  <div id="articles" class="mx-auto max-w-6xl px-4 scroll-mt-4">
    {featuredPosts.length > 0 && (
      <section class="py-8">
        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">Pick Up</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {featuredPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              featured
            />
          ))}
        </div>
      </section>
    )}

    <hr class="border-border" />

    <section class="py-8">
      <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">All Articles</h2>
      {restPosts.length === 0 ? (
        <p class="text-text-secondary">まだ他の記事がありません。</p>
      ) : (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {restPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    {Object.entries(categories).map(([slug, cat]) => {
      const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
      if (catPosts.length === 0) return null;
      return (
        <>
          <hr class="border-border" />
          <section class="py-8">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-bold uppercase tracking-wider" style={`color: ${cat.color}`}>
                {cat.name}
              </h2>
              <a href={`/category/${slug}/`} class="text-[13px] text-text-muted hover:text-accent transition-colors">
                すべて見る &rarr;
              </a>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {catPosts.map((post) => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  slug={post.id}
                />
              ))}
            </div>
          </section>
        </>
      );
    })}
  </div>
</Base>
