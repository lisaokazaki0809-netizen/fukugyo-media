---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.slice(0, 3);
const restPosts = sortedPosts.slice(3);
---

<Base>
  <!-- Hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-10 md:py-14">
      <h1 class="text-3xl md:text-4xl font-bold text-text tracking-tight mb-3">
        {SITE.title}
      </h1>
      <p class="text-text-secondary text-sm md:text-base max-w-lg leading-relaxed">
        {SITE.description}
      </p>
      <!-- Category pills -->
      <div class="flex flex-wrap gap-2 mt-6">
        {Object.entries(categories).map(([slug, cat]) => (
          <a
            href={`/category/${slug}/`}
            class="text-[12px] font-semibold px-3 py-1.5 rounded-full transition-all hover:shadow-sm"
            style={`color: ${cat.color}; background-color: ${cat.bgColor}`}
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4">
    <!-- Featured posts -->
    {featuredPosts.length > 0 && (
      <section class="py-8">
        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">Pick Up</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {featuredPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              featured
            />
          ))}
        </div>
      </section>
    )}

    <!-- Divider -->
    <hr class="border-border" />

    <!-- All posts -->
    <section class="py-8">
      <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">All Articles</h2>
      {restPosts.length === 0 ? (
        <p class="text-text-secondary">まだ他の記事がありません。</p>
      ) : (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {restPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    <!-- Category sections -->
    {Object.entries(categories).map(([slug, cat]) => {
      const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
      if (catPosts.length === 0) return null;
      return (
        <>
          <hr class="border-border" />
          <section class="py-8">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-bold uppercase tracking-wider" style={`color: ${cat.color}`}>
                {cat.name}
              </h2>
              <a href={`/category/${slug}/`} class="text-[13px] text-text-muted hover:text-accent transition-colors">
                すべて見る &rarr;
              </a>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {catPosts.map((post) => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  slug={post.id}
                />
              ))}
            </div>
          </section>
        </>
      );
    })}
  </div>
</Base>
