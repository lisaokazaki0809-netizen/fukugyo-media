---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import Sidebar from '../components/Sidebar.astro';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.slice(0, 3);
const restPosts = sortedPosts.slice(3);
---

<Base hideHeader>
  <!-- Hero: 画像を丸ごと表示。クリック可能な領域を重ねる -->
  <section class="relative">
    <div class="mx-auto max-w-6xl">
      <!-- 画像MAP用にposition relativeのラッパーが必要 -->
      <div class="relative">
        <img
          src="/images/hero.jpg"
          alt="副業・投資・キャリアのリアルを記録するメディア わらじ二足"
          class="w-full h-auto block"
          width="1536"
          height="1024"
          fetchpriority="high"
          id="hero-img"
        />
        <!-- ロゴ上書き: 画像内の「わらじ二足」を「副業media」に差し替え -->
        <div id="hero-logo" class="absolute flex items-center" style="background:#f8fafc;">
          <span style="font-size:inherit; font-weight:800; color:#1a1a2e; letter-spacing:-0.02em; white-space:nowrap;">副業media</span>
        </div>
        <!-- リンクはJSでピクセル単位で配置する -->
        <div id="hero-links"></div>
      </div>
    </div>
  </section>

  <!-- ① 分岐導線: あなたはどれ？ -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-10">
      <p class="text-center text-text-muted text-sm mb-2">まずはここから</p>
      <h2 class="text-center text-xl md:text-2xl font-bold text-text mb-8">あなたが今、気になっているのは？</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
        <a href="/category/investment/" class="group block text-center p-6 rounded-xl border-2 border-border hover:border-accent hover:shadow-md transition-all">
          <span class="text-3xl block mb-3">💰</span>
          <span class="text-[15px] font-bold text-text group-hover:text-accent transition-colors">副業・投資を始めたい</span>
          <span class="block text-[12px] text-text-muted mt-1">NISA、高配当株、せどりなど</span>
        </a>
        <a href="/category/jobchange/" class="group block text-center p-6 rounded-xl border-2 border-border hover:border-accent hover:shadow-md transition-all">
          <span class="text-3xl block mb-3">🔄</span>
          <span class="text-[15px] font-bold text-text group-hover:text-accent transition-colors">転職を考えている</span>
          <span class="block text-[12px] text-text-muted mt-1">エージェント、面接、職務経歴書</span>
        </a>
        <a href="/category/career/" class="group block text-center p-6 rounded-xl border-2 border-border hover:border-accent hover:shadow-md transition-all">
          <span class="text-3xl block mb-3">📈</span>
          <span class="text-[15px] font-bold text-text group-hover:text-accent transition-colors">年収を上げたい</span>
          <span class="block text-[12px] text-text-muted mt-1">資格、スキルアップ、昇進戦略</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ② 初心者導線: はじめての方へ -->
  <section class="bg-bg-soft border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-10">
      <div class="max-w-3xl mx-auto">
        <p class="text-accent text-sm font-bold mb-1">はじめての方へ</p>
        <h2 class="text-lg font-bold text-text mb-5">迷ったら、まずこの3本から読んでください</h2>
        <div class="space-y-3">
          <a href="/posts/side-job-beginners-guide/" class="flex items-center gap-4 bg-white p-4 rounded-xl border border-border hover:border-accent/30 hover:shadow-sm transition-all group">
            <span class="text-2xl shrink-0">1</span>
            <div>
              <p class="font-bold text-[14px] text-text group-hover:text-accent transition-colors">副業を始める前に最低限やっておくべき5つの準備</p>
              <p class="text-[12px] text-text-muted mt-0.5">就業規則、確定申告、時間管理。ここを飛ばすと後で痛い目に合います</p>
            </div>
          </a>
          <a href="/posts/nisa-tsumitate-hajimete/" class="flex items-center gap-4 bg-white p-4 rounded-xl border border-border hover:border-accent/30 hover:shadow-sm transition-all group">
            <span class="text-2xl shrink-0">2</span>
            <div>
              <p class="font-bold text-[14px] text-text group-hover:text-accent transition-colors">新NISAのつみたて投資枠、初心者が選ぶべきファンドはこの3本</p>
              <p class="text-[12px] text-text-muted mt-0.5">オルカン vs S&P500。結論と理由をシンプルにまとめました</p>
            </div>
          </a>
          <a href="/posts/career-nenshu-koujou/" class="flex items-center gap-4 bg-white p-4 rounded-xl border border-border hover:border-accent/30 hover:shadow-sm transition-all group">
            <span class="text-2xl shrink-0">3</span>
            <div>
              <p class="font-bold text-[14px] text-text group-hover:text-accent transition-colors">30代で年収100万円アップは可能か？5つの方法を比較した結果</p>
              <p class="text-[12px] text-text-muted mt-0.5">転職、副業、資格、昇進。どれが一番現実的か</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 記事一覧 + サイドバー -->
  <div id="articles" class="mx-auto max-w-7xl px-4 scroll-mt-4">
    <div class="flex flex-col lg:flex-row gap-8">
    <div class="flex-1 min-w-0">
    {featuredPosts.length > 0 && (
      <section class="py-8">
        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">Pick Up</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {featuredPosts.map((post, i) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              featured
              index={i}
            />
          ))}
        </div>
      </section>
    )}

    <hr class="border-border" />

    <section class="py-8">
      <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">All Articles</h2>
      {restPosts.length === 0 ? (
        <p class="text-text-secondary">まだ他の記事がありません。</p>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2">
          {restPosts.map((post, i) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              index={i + 1}
            />
          ))}
        </div>
      )}
    </section>

    {Object.entries(categories).map(([slug, cat]) => {
      const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
      if (catPosts.length === 0) return null;
      return (
        <>
          <hr class="border-border" />
          <section class="py-8">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-bold uppercase tracking-wider" style={`color: ${cat.color}`}>
                {cat.name}
              </h2>
              <a href={`/category/${slug}/`} class="text-[13px] text-text-muted hover:text-accent transition-colors">
                すべて見る &rarr;
              </a>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              {catPosts.map((post, i) => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  slug={post.id}
                  index={i}
                />
              ))}
            </div>
          </section>
        </>
      );
    })}

    <!-- ④ さりげないCTA -->
    <section class="py-12">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-text-muted text-sm mb-2">全記事を探す</p>
        <h2 class="text-lg font-bold text-text mb-4">ジャンル別に記事をまとめています</h2>
        <div class="flex flex-wrap justify-center gap-2">
          {Object.entries(categories).map(([slug, cat]) => (
            <a
              href={`/category/${slug}/`}
              class="text-[13px] font-medium px-4 py-2 rounded-full border border-border hover:border-accent hover:text-accent transition-all"
              style={`color: ${cat.color}`}
            >
              {cat.name}の記事一覧
            </a>
          ))}
        </div>
        <a href="/about/" class="inline-block mt-6 text-[13px] text-text-muted hover:text-accent transition-colors">
          このサイトについて &rarr;
        </a>
      </div>
    </section>
    </div><!-- /flex-1 -->

    <!-- サイドバー（PCのみ） -->
    <div class="hidden lg:block w-72 shrink-0 pt-8">
      <Sidebar />
    </div>

    </div><!-- /flex row -->
  </div>
</Base>

<script is:inline>
// 画像の元サイズに対するピクセル座標でリンクを定義
// 元画像: 1536 x 1024
var LINKS = [
  // ヘッダーナビ
  { x: 32, y: 18, w: 180, h: 55, href: '/', label: 'トップ' },
  { x: 710, y: 17, w: 100, h: 55, href: '/category/investment/', label: '投資' },
  { x: 834, y: 18, w: 115, h: 55, href: '/category/ai/', label: 'AI副業' },
  { x: 983, y: 18, w: 85, h: 55, href: '/category/entrepreneur/', label: '起業' },
  { x: 1112, y: 19, w: 85, h: 55, href: '/category/jobchange/', label: '転職' },
  { x: 1234, y: 18, w: 165, h: 55, href: '/category/career/', label: 'キャリアアップ' },
  { x: 1411, y: 18, w: 110, h: 55, href: '/about/', label: 'About' },

  // CTAボタン
  { x: 74, y: 461, w: 440, h: 60, href: '#articles', label: '記事を見る' },

  // カテゴリカード5つ
  { x: 74, y: 568, w: 275, h: 170, href: '/category/investment/', label: '投資' },
  { x: 355, y: 565, w: 275, h: 170, href: '/category/ai/', label: 'AI副業' },
  { x: 637, y: 568, w: 275, h: 170, href: '/category/entrepreneur/', label: '起業' },
  { x: 915, y: 569, w: 275, h: 170, href: '/category/jobchange/', label: '転職' },
  { x: 1197, y: 568, w: 275, h: 170, href: '/category/career/', label: 'キャリアアップ' },

  // このサイトについて
  { x: 43, y: 747, w: 1476, h: 290, href: '/about/', label: 'このサイトについて' },
];

function placeLinks() {
  var img = document.getElementById('hero-img');
  var container = document.getElementById('hero-links');
  if (!img || !container) return;

  var displayW = img.clientWidth;
  var displayH = img.clientHeight;
  var origW = 1536;
  var origH = 1024;
  var scaleX = displayW / origW;
  var scaleY = displayH / origH;

  // ロゴ上書きの位置とサイズを合わせる
  var logo = document.getElementById('hero-logo');
  if (logo) {
    logo.style.left = (32 * scaleX) + 'px';
    logo.style.top = (18 * scaleY) + 'px';
    logo.style.width = (180 * scaleX) + 'px';
    logo.style.height = (55 * scaleY) + 'px';
    logo.style.fontSize = (28 * scaleX) + 'px';
    logo.style.paddingLeft = (6 * scaleX) + 'px';
  }

  container.innerHTML = '';

  for (var i = 0; i < LINKS.length; i++) {
    var link = LINKS[i];
    var a = document.createElement('a');
    a.href = link.href;
    a.setAttribute('aria-label', link.label);
    a.style.position = 'absolute';
    a.style.left = (link.x * scaleX) + 'px';
    a.style.top = (link.y * scaleY) + 'px';
    a.style.width = (link.w * scaleX) + 'px';
    a.style.height = (link.h * scaleY) + 'px';
    a.style.cursor = 'pointer';
    // 本番: 透明リンク
    container.appendChild(a);
  }
}

window.addEventListener('load', placeLinks);
window.addEventListener('resize', placeLinks);
</script>
