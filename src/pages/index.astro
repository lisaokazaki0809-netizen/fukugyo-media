---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.slice(0, 3);
const restPosts = sortedPosts.slice(3);
---

<Base hideHeader>
  <!-- Hero: 画像全体を表示し、透明リンクを重ねる -->
  <section class="relative">
    <div class="mx-auto max-w-6xl">
      <img
        src="/images/hero.jpg"
        alt="副業・投資・キャリアのリアルを記録するメディア わらじ二足"
        class="w-full h-auto block"
        width="1536"
        height="1024"
        fetchpriority="high"
      />

      <!-- ヘッダーナビのリンク（画像内の上部メニュー） -->
      <a href="/" class="absolute top-[1%] left-[2%] w-[8%] h-[4.5%]" aria-label="トップ"></a>
      <a href="/category/investment/" class="absolute top-[1.5%] left-[42%] w-[5%] h-[3.5%]" aria-label="投資"></a>
      <a href="/category/ai/" class="absolute top-[1.5%] left-[48%] w-[6%] h-[3.5%]" aria-label="AI副業"></a>
      <a href="/category/entrepreneur/" class="absolute top-[1.5%] left-[55%] w-[4%] h-[3.5%]" aria-label="起業"></a>
      <a href="/category/jobchange/" class="absolute top-[1.5%] left-[60%] w-[4%] h-[3.5%]" aria-label="転職"></a>
      <a href="/category/career/" class="absolute top-[1.5%] left-[65%] w-[9%] h-[3.5%]" aria-label="キャリアアップ"></a>
      <a href="/about/" class="absolute top-[1.5%] left-[76%] w-[5%] h-[3.5%]" aria-label="About"></a>

      <!-- CTAボタン -->
      <a href="#articles" class="absolute top-[39%] left-[3%] w-[28%] h-[5.5%] rounded-full" aria-label="記事を見る"></a>

      <!-- カテゴリカード5つ（画像内の下部カード） -->
      <a href="/category/investment/" class="absolute top-[50%] left-[2%] w-[18.5%] h-[15%] rounded-xl" aria-label="投資"></a>
      <a href="/category/ai/" class="absolute top-[50%] left-[21.5%] w-[18.5%] h-[15%] rounded-xl" aria-label="AI副業"></a>
      <a href="/category/entrepreneur/" class="absolute top-[50%] left-[41%] w-[18.5%] h-[15%] rounded-xl" aria-label="起業"></a>
      <a href="/category/jobchange/" class="absolute top-[50%] left-[60.5%] w-[18.5%] h-[15%] rounded-xl" aria-label="転職"></a>
      <a href="/category/career/" class="absolute top-[50%] left-[80%] w-[18.5%] h-[15%] rounded-xl" aria-label="キャリアアップ"></a>

      <!-- Aboutの「もっと詳しく」的なリンク -->
      <a href="/about/" class="absolute top-[70%] left-[2%] w-[96%] h-[28%] rounded-xl" aria-label="このサイトについて"></a>
    </div>
  </section>

  <!-- 記事一覧 -->
  <div id="articles" class="mx-auto max-w-6xl px-4 scroll-mt-4">
    <!-- Featured posts -->
    {featuredPosts.length > 0 && (
      <section class="py-8">
        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">Pick Up</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {featuredPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              featured
            />
          ))}
        </div>
      </section>
    )}

    <hr class="border-border" />

    <!-- All posts -->
    <section class="py-8">
      <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">All Articles</h2>
      {restPosts.length === 0 ? (
        <p class="text-text-secondary">まだ他の記事がありません。</p>
      ) : (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {restPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    <!-- Category sections -->
    {Object.entries(categories).map(([slug, cat]) => {
      const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
      if (catPosts.length === 0) return null;
      return (
        <>
          <hr class="border-border" />
          <section class="py-8">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-bold uppercase tracking-wider" style={`color: ${cat.color}`}>
                {cat.name}
              </h2>
              <a href={`/category/${slug}/`} class="text-[13px] text-text-muted hover:text-accent transition-colors">
                すべて見る &rarr;
              </a>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {catPosts.map((post) => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  slug={post.id}
                />
              ))}
            </div>
          </section>
        </>
      );
    })}
  </div>
</Base>
