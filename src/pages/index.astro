---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { categories, getCategoryColor, getCategoryBgColor } from '../lib/categories';
import { SITE } from '../lib/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = sortedPosts.slice(0, 3);
const restPosts = sortedPosts.slice(3);
---

<Base hideHeader>
  <!-- Hero (画像内にナビ・テキスト・ボタンが含まれている) -->
  <section class="border-b border-border relative">
    <div class="mx-auto max-w-6xl">
      <img
        src="/images/hero.jpg"
        alt="副業・投資・キャリアのリアルを記録するメディア わらじ二足"
        class="w-full h-auto"
        width="1344"
        height="640"
        fetchpriority="high"
      />
      <!-- ボタンのクリック領域（画像内のCTAボタン位置に合わせる） -->
      <a
        href="#articles"
        class="absolute bottom-[22%] left-[4%] md:left-[3%] w-[30%] md:w-[28%] h-[6%] md:h-[7%] rounded-full"
        aria-label="情報を比較して、自分らしい選択を見つけよう"
      ></a>
    </div>
  </section>

  <div id="articles" class="mx-auto max-w-6xl px-4 scroll-mt-4">
    <!-- Featured posts -->
    {featuredPosts.length > 0 && (
      <section class="py-8">
        <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">Pick Up</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {featuredPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              featured
            />
          ))}
        </div>
      </section>
    )}

    <!-- Divider -->
    <hr class="border-border" />

    <!-- All posts -->
    <section class="py-8">
      <h2 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-5">All Articles</h2>
      {restPosts.length === 0 ? (
        <p class="text-text-secondary">まだ他の記事がありません。</p>
      ) : (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {restPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    <!-- Category sections -->
    {Object.entries(categories).map(([slug, cat]) => {
      const catPosts = sortedPosts.filter(p => p.data.category === slug).slice(0, 3);
      if (catPosts.length === 0) return null;
      return (
        <>
          <hr class="border-border" />
          <section class="py-8">
            <div class="flex items-center justify-between mb-5">
              <h2 class="text-sm font-bold uppercase tracking-wider" style={`color: ${cat.color}`}>
                {cat.name}
              </h2>
              <a href={`/category/${slug}/`} class="text-[13px] text-text-muted hover:text-accent transition-colors">
                すべて見る &rarr;
              </a>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {catPosts.map((post) => (
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  slug={post.id}
                />
              ))}
            </div>
          </section>
        </>
      );
    })}
  </div>
</Base>
