---
import Base from '../layouts/Base.astro';
---

<Base title="ページが見つかりません">
  <div class="mx-auto max-w-2xl px-4 py-20 text-center">
    <p class="text-6xl font-bold text-text-muted mb-4">404</p>
    <h1 class="text-xl font-bold text-text mb-3">ページが見つかりません</h1>
    <p class="text-[14px] text-text-secondary mb-8">お探しのページは削除されたか、URLが変更された可能性があります。</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="bg-accent text-white text-[13px] font-bold px-6 py-2.5 rounded-lg hover:opacity-90 transition-opacity">
        トップページへ戻る
      </a>
      <a href="/search/" class="border border-border text-text text-[13px] font-medium px-6 py-2.5 rounded-lg hover:bg-bg-muted transition-colors">
        記事を検索する
      </a>
    </div>
  </div>
</Base>
