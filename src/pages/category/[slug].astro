---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { categories, type CategorySlug } from '../../lib/categories';

export function getStaticPaths() {
  return Object.keys(categories).map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const category = categories[slug as CategorySlug];

const posts = await getCollection('posts', ({ data }) => !data.draft && data.category === slug);
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base title={`${category.name}の記事一覧`} description={category.description} breadcrumbs={[{ name: category.name, href: `/category/${slug}/` }]}>
  <!-- Category hero -->
  <section class="bg-white border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-8">
      <div class="flex flex-col md:flex-row md:items-center gap-6">
        <div class="flex-1">
          <span
            class="inline-block text-[11px] font-bold uppercase tracking-wider px-2.5 py-1 rounded mb-3"
            style={`color: ${category.color}; background-color: ${category.bgColor}`}
          >
            Category
          </span>
          <h1 class="text-2xl font-bold text-text mb-2">{category.name}</h1>
          <p class="text-text-secondary text-sm">{category.description}</p>
        </div>
        <div class="w-full md:w-56 h-32 rounded-xl overflow-hidden shrink-0">
          <img src={category.image} alt="" class="w-full h-full object-cover" width="224" height="128" />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-8">
    {sortedPosts.length === 0 ? (
      <p class="text-text-secondary">このカテゴリにはまだ記事がありません。</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {sortedPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
          />
        ))}
      </div>
    )}
  </section>
</Base>
