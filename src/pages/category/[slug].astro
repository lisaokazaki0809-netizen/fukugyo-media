---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { categories, type CategorySlug } from '../../lib/categories';

export function getStaticPaths() {
  return Object.keys(categories).map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const category = categories[slug as CategorySlug];

const posts = await getCollection('posts', ({ data }) => !data.draft && data.category === slug);
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base title={`${category.name}の記事一覧`} description={category.description} breadcrumbs={[{ name: category.name, href: `/category/${slug}/` }]}>
  <section class="mx-auto max-w-5xl px-4 py-10">
    <h1 class="text-2xl font-bold text-text mb-2">{category.name}</h1>
    <p class="text-text-light text-sm mb-8">{category.description}</p>

    {sortedPosts.length === 0 ? (
      <p class="text-text-light">この カテゴリにはまだ記事がありません。</p>
    ) : (
      <div class="grid gap-4 md:grid-cols-2">
        {sortedPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
          />
        ))}
      </div>
    )}
  </section>
</Base>
