---
import { getCategoryName, getCategoryColor, getCategoryBgColor } from '../lib/categories';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  featured?: boolean;
}

const { title, description, pubDate, category, slug, featured = false } = Astro.props;
const catColor = getCategoryColor(category);
const catBgColor = getCategoryBgColor(category);

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<article class="group h-full">
  <a href={`/posts/${slug}/`} class="block h-full">
    <div class={`h-full bg-white rounded-xl overflow-hidden transition-all duration-200 ${featured ? 'shadow-sm hover:shadow-md' : 'hover:shadow-sm'} border border-transparent hover:border-border`}>
      <div class="p-5">
        <div class="flex items-center gap-2 mb-3">
          <span
            class="text-[11px] font-bold uppercase tracking-wide px-2 py-0.5 rounded"
            style={`color: ${catColor}; background-color: ${catBgColor}`}
          >
            {getCategoryName(category)}
          </span>
          <time datetime={pubDate.toISOString()} class="text-[12px] text-text-muted">
            {formattedDate}
          </time>
        </div>
        <h3 class={`font-bold text-text leading-snug group-hover:text-accent transition-colors mb-2 ${featured ? 'text-lg' : 'text-[15px]'}`}>
          {title}
        </h3>
        <p class="text-[13px] text-text-secondary line-clamp-2 leading-relaxed">
          {description}
        </p>
      </div>
    </div>
  </a>
</article>
