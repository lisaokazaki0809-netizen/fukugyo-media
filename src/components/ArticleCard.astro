---
import { getCategoryName, getCategoryColor, getCategoryBgColor, getCategoryImage } from '../lib/categories';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  featured?: boolean;
  index?: number;
}

const { title, description, pubDate, category, slug, featured = false, index = 0 } = Astro.props;
const catColor = getCategoryColor(category);
const catBgColor = getCategoryBgColor(category);
const catImage = getCategoryImage(category, index);

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<article class="group h-full">
  <a href={`/posts/${slug}/`} class="block h-full">
    <div class={`h-full bg-white rounded-xl overflow-hidden transition-all duration-200 ${featured ? 'shadow-sm hover:shadow-md' : 'hover:shadow-sm'} border border-transparent hover:border-border`}>
      <!-- Thumbnail -->
      <div class="aspect-[334/240] overflow-hidden bg-bg-muted">
        <img
          src={catImage}
          alt=""
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
          width="334"
          height="240"
        />
      </div>
      <div class="p-4">
        <div class="flex items-center gap-2 mb-2.5">
          <span
            class="text-[11px] font-bold uppercase tracking-wide px-2 py-0.5 rounded"
            style={`color: ${catColor}; background-color: ${catBgColor}`}
          >
            {getCategoryName(category)}
          </span>
          <time datetime={pubDate.toISOString()} class="text-[12px] text-text-muted">
            {formattedDate}
          </time>
        </div>
        <h3 class={`font-bold text-text leading-snug group-hover:text-accent transition-colors mb-1.5 ${featured ? 'text-[16px]' : 'text-[15px]'}`}>
          {title}
        </h3>
        <p class="text-[13px] text-text-secondary line-clamp-2 leading-relaxed">
          {description}
        </p>
      </div>
    </div>
  </a>
</article>
