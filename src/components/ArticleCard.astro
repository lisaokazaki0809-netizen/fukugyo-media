---
import { getCategoryName, getCategoryColor, getCategoryBgColor } from '../lib/categories';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
}

const { title, description, pubDate, category, slug } = Astro.props;
const catColor = getCategoryColor(category);
const catBgColor = getCategoryBgColor(category);

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group h-full">
  <a href={`/posts/${slug}/`} class="block h-full">
    <div class="h-full bg-white border border-border rounded-xl overflow-hidden hover:shadow-lg hover:border-border/50 transition-all duration-200">
      <!-- Category color bar -->
      <div class="h-1.5" style={`background-color: ${catColor}`}></div>
      <div class="p-5">
        <div class="flex items-center gap-3 mb-3">
          <span
            class="text-xs font-semibold px-2.5 py-1 rounded-md"
            style={`color: ${catColor}; background-color: ${catBgColor}`}
          >
            {getCategoryName(category)}
          </span>
          <time datetime={pubDate.toISOString()} class="text-xs text-text-muted">
            {formattedDate}
          </time>
        </div>
        <h3 class="text-base font-bold text-text leading-snug group-hover:text-accent transition-colors mb-2">
          {title}
        </h3>
        <p class="text-sm text-text-light line-clamp-2 leading-relaxed">
          {description}
        </p>
      </div>
    </div>
  </a>
</article>
