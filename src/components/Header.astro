---
import { categories } from '../lib/categories';
import { SITE } from '../lib/site';
---

<header class="bg-primary text-white sticky top-0 z-50">
  <div class="mx-auto max-w-6xl px-4">
    <!-- Top bar -->
    <div class="flex items-center justify-between py-3">
      <a href="/" class="text-xl font-bold tracking-tight hover:opacity-90 transition-opacity">
        {SITE.title}
      </a>
      <div class="hidden md:flex items-center gap-4 text-sm">
        <a href="/about/" class="text-white/70 hover:text-white transition-colors">このサイトについて</a>
        <a href="/search/" class="text-white/70 hover:text-white transition-colors flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          検索
        </a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden p-2 text-white/70 hover:text-white" aria-label="メニューを開く">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <!-- Category nav -->
    <nav class="hidden md:flex items-center gap-1 pb-2 -mx-2 overflow-x-auto">
      {Object.entries(categories).map(([slug, cat]) => (
        <a
          href={`/category/${slug}/`}
          class="px-3 py-1.5 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-md transition-colors whitespace-nowrap"
        >
          {cat.name}
        </a>
      ))}
    </nav>
  </div>
  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden bg-primary-light border-t border-white/10">
    <div class="px-4 py-3 space-y-1">
      {Object.entries(categories).map(([slug, cat]) => (
        <a href={`/category/${slug}/`} class="block py-2 text-sm text-white/70 hover:text-white transition-colors">
          {cat.name}
        </a>
      ))}
      <div class="border-t border-white/10 mt-2 pt-2">
        <a href="/about/" class="block py-2 text-sm text-white/70 hover:text-white transition-colors">このサイトについて</a>
        <a href="/search/" class="block py-2 text-sm text-white/70 hover:text-white transition-colors">検索</a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
