---
import { categories } from '../lib/categories';
import { SITE } from '../lib/site';
---

<header class="bg-white border-b border-border sticky top-0 z-50">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="text-lg font-bold text-text tracking-tight hover:text-accent transition-colors">
        {SITE.title}
      </a>
      <nav class="hidden md:flex items-center gap-1">
        {Object.entries(categories).map(([slug, cat]) => (
          <a
            href={`/category/${slug}/`}
            class="px-3 py-1.5 text-[13px] font-medium text-text-secondary hover:text-accent hover:bg-bg-muted rounded-lg transition-colors"
          >
            {cat.name}
          </a>
        ))}
        <div class="w-px h-5 bg-border mx-1.5"></div>
        <a href="/about/" class="px-3 py-1.5 text-[13px] text-text-muted hover:text-accent rounded-lg transition-colors">About</a>
        <a href="/search/" class="p-2 text-text-muted hover:text-accent rounded-lg transition-colors" aria-label="検索">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </a>
      </nav>
      <button id="mobile-menu-btn" class="md:hidden p-2 -mr-2 text-text-secondary hover:text-text" aria-label="メニュー">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <nav id="mobile-menu" class="hidden md:hidden border-t border-border bg-white">
    <div class="px-4 py-2 space-y-0.5">
      {Object.entries(categories).map(([slug, cat]) => (
        <a href={`/category/${slug}/`} class="block py-2.5 text-sm text-text-secondary hover:text-accent transition-colors">{cat.name}</a>
      ))}
      <div class="border-t border-border my-1"></div>
      <a href="/about/" class="block py-2.5 text-sm text-text-muted hover:text-accent transition-colors">About</a>
      <a href="/search/" class="block py-2.5 text-sm text-text-muted hover:text-accent transition-colors">検索</a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
