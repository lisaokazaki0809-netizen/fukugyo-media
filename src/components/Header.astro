---
import { categories } from '../lib/categories';
import { SITE } from '../lib/site';
---

<header class="bg-white border-b border-border sticky top-0 z-50">
  <div class="mx-auto max-w-7xl px-4">
    <div class="flex items-center justify-between h-14">
      <div class="flex items-center gap-3">
        <a href="/" class="text-lg font-bold text-text tracking-tight hover:text-accent transition-colors">
          {SITE.title}
        </a>
        <span class="hidden md:inline text-[11px] text-text-muted">副業・投資・キャリアのリアルを記録するメディア</span>
      </div>
      <nav class="hidden md:flex items-center gap-1">
        <a href="/search/" class="px-2.5 py-1.5 text-[13px] text-text-secondary hover:text-accent rounded-lg transition-colors flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          検索
        </a>
        <div class="relative group">
          <button class="px-2.5 py-1.5 text-[13px] text-text-secondary hover:text-accent rounded-lg transition-colors flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            カテゴリ
          </button>
          <div class="absolute top-full left-0 mt-1 bg-white border border-border rounded-xl shadow-lg py-2 w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            {Object.entries(categories).map(([slug, cat]) => (
              <a href={`/category/${slug}/`} class="block px-4 py-2 text-[13px] text-text-secondary hover:text-accent hover:bg-bg-soft transition-colors">{cat.name}</a>
            ))}
          </div>
        </div>
        <a href="/#popular" class="px-2.5 py-1.5 text-[13px] text-text-secondary hover:text-accent rounded-lg transition-colors">人気記事</a>
        <a href="/#latest" class="px-2.5 py-1.5 text-[13px] text-text-secondary hover:text-accent rounded-lg transition-colors">新着記事</a>
        <a href="/about/" class="px-2.5 py-1.5 text-[13px] text-text-secondary hover:text-accent rounded-lg transition-colors">お問い合わせ</a>
      </nav>
      <button id="mobile-menu-btn" class="md:hidden p-2 -mr-2 text-text-secondary hover:text-text" aria-label="メニュー">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <nav id="mobile-menu" class="hidden md:hidden border-t border-border bg-white">
    <div class="px-4 py-2 space-y-0.5">
      {Object.entries(categories).map(([slug, cat]) => (
        <a href={`/category/${slug}/`} class="block py-2.5 text-sm text-text-secondary hover:text-accent transition-colors">{cat.name}</a>
      ))}
      <div class="border-t border-border my-1"></div>
      <a href="/about/" class="block py-2.5 text-sm text-text-muted hover:text-accent transition-colors">About</a>
      <a href="/search/" class="block py-2.5 text-sm text-text-muted hover:text-accent transition-colors">検索</a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
